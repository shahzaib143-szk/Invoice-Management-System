<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ims.gui.controller.UserDashboardController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f8f9fa;">

    <top>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #34495e;">
            <Label text="User Dashboard"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="welcomeLabel"
                   text="Welcome"
                   style="-fx-text-fill: #ecf0f1;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Label text="My Invoices"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TableView fx:id="invoiceTable" prefHeight="450">
                <columns>
                    <TableColumn fx:id="idColumn" text="Invoice ID" prefWidth="120"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="180"/>
                    <TableColumn fx:id="totalColumn" text="Total" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Refresh" onAction="#refreshInvoices"
                        prefWidth="120" prefHeight="35"/>
                <Button text="Logout" onAction="#logout"
                        prefWidth="120" prefHeight="35"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>